<!--
  UArm Swift Pro URDF with parallel linkage constraints.

  The arm has 3 physical servos. Joint names follow the libswiftpro
  convention used throughout SwiftRos2:
    base   — base rotation       (servo 0)  Z axis
    left   — shoulder elevation  (servo 1)  Y axis
    right  — elbow / forearm     (servo 2)  Y axis

  All other joints are mechanically constrained by the parallel linkage
  and expressed as <mimic> joints. robot_state_publisher computes and
  broadcasts their values automatically from base/left/right.

  The hardware node (swiftpro_hardware) publishes JointState for
  base, left, right only.

  Parallel linkage geometry — two four-bar loops:

  Loop 1 — upper arm parallelogram:
    Link2  (left)         — upper arm front rod — driven by servo 1
    Link5  (link5_mimic)  — upper arm rear rod  — mimics left × -1.0
    Link4  (link4_mimic)  — triangular connector — mimics right × +1.0
    The triangle (Link4) transfers elbow rotation to the wrist chain.
    Shoulder movement is fully cancelled within this loop — it never
    reaches the end effector.

  Loop 2 — wrist parallelogram:
    Link6  (link6_mimic)  — wrist rear upper — mimics left  × +1.0
    Link7  (link7_mimic)  — wrist rear lower — mimics right × +1.0
    Link8  (link8_mimic)  — end effector mount — mimics right × -1.0
    Only elbow rotation (right) reaches the end effector.
    link8_mimic cancels it to keep the gripper level.

  Verified against physical hardware:
    - Moving shoulder only: forearm links stay parallel ✓
    - Moving elbow only:    upper arm links stay parallel ✓
    - link8_mimic compensation source is right, not left ✓

  link9_fixed is fixed — the gripper jaw is not servo-driven in the
  base UArm Swift Pro configuration.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="swiftpro">

<!-- ============================================================ -->
<!-- Dummy root — avoids KDL inertia warning on root link         -->
<!-- ============================================================ -->
<link name="dummy_base"/>

<joint name="dummy_base_to_base" type="fixed">
  <parent link="dummy_base"/>
  <child link="Base"/>
  <origin xyz="0 0 0" rpy="0 0 0"/>
</joint>

<!-- ============================================================ -->
<!-- Base                                                          -->
<!-- ============================================================ -->
<link name="Base">
  <inertial>
    <origin xyz="0.010476 0.000747 0.035226" rpy="0 0 0"/>
    <mass value="1.886"/>
    <inertia ixx="0.001196219" ixy="-0.000029358" ixz="0.000014859"
             iyy="0.001147997" iyz="0.000016274"  izz="0.001425617"/>
  </inertial>
  <visual>
    <geometry>
      <mesh filename="package://swiftpro_resources/urdf/Base.STL"/>
    </geometry>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <material name="dark_grey">
      <color rgba="0.3 0.3 0.3 1"/>
    </material>
  </visual>
</link>

<!-- ============================================================ -->
<!-- Link1 — base turntable                                        -->
<!-- base — base rotation (Z axis) — SERVO 0                       -->
<!-- ============================================================ -->
<link name="Link1">
  <inertial>
    <origin xyz="-0.002175 0 0.029097" rpy="0 0 0"/>
    <mass value="0.2141"/>
    <inertia ixx="0.000496945" ixy="-0.000000082" ixz="-0.000002744"
             iyy="0.000150389" iyz="-0.000000002" izz="0.000522487"/>
  </inertial>
  <visual>
    <geometry>
      <mesh filename="package://swiftpro_resources/urdf/Link1.STL"/>
    </geometry>
    <origin xyz="0 0 -0.0723" rpy="0 0 0"/>
    <material name="dark_grey"/>
  </visual>
</link>

<joint name="base" type="revolute">
  <axis xyz="0 0 1"/>
  <limit effort="1000.0" lower="-1.57" upper="1.57" velocity="2.0"/>
  <parent link="Base"/>
  <child link="Link1"/>
  <origin xyz="0 0 0.0723" rpy="0 0 0"/>
</joint>

<!-- ============================================================ -->
<!-- Link2 — upper arm front rod                                   -->
<!-- left — shoulder elevation (Y axis) — SERVO 1                  -->
<!-- ============================================================ -->
<link name="Link2">
  <inertial>
    <origin xyz="-0.001071 0.001101 0.053193" rpy="0 0 0"/>
    <mass value="0.026"/>
    <inertia ixx="0.000061744" ixy="-0.000000025" ixz="-0.000000763"
             iyy="0.000062096" iyz="-0.000001053" izz="0.000002942"/>
  </inertial>
  <visual>
    <geometry>
      <mesh filename="package://swiftpro_resources/urdf/Link2.STL"/>
    </geometry>
    <origin xyz="-0.0132 0 -0.1056" rpy="0 0 0"/>
    <material name="dark_grey"/>
  </visual>
</link>

<joint name="left" type="revolute">
  <axis xyz="0 1 0"/>
  <limit effort="1000.0" lower="-1.57" upper="1.57" velocity="2.0"/>
  <parent link="Link1"/>
  <child link="Link2"/>
  <origin xyz="0.0132 0 0.0333" rpy="0 0 0"/>
</joint>

<!-- ============================================================ -->
<!-- Link3 — forearm                                               -->
<!-- right — elbow (Y axis) — SERVO 2                              -->
<!-- ============================================================ -->
<link name="Link3">
  <inertial>
    <origin xyz="0.101948 -0.00022 0.011917" rpy="0 0 0"/>
    <mass value="0.023"/>
    <inertia ixx="0.000001982" ixy="0.000000483" ixz="-0.000005373"
             iyy="0.000081264" iyz="0.000000008" izz="0.000080538"/>
  </inertial>
  <visual>
    <geometry>
      <mesh filename="package://swiftpro_resources/urdf/Link3.STL"/>
    </geometry>
    <origin xyz="-0.0132 0 -0.24767" rpy="0 0 0"/>
    <material name="dark_grey"/>
  </visual>
</link>

<joint name="right" type="revolute">
  <axis xyz="0 1 0"/>
  <limit effort="1000.0" lower="-1.45" upper="1.45" velocity="2.0"/>
  <parent link="Link2"/>
  <child link="Link3"/>
  <origin xyz="0 0 0.14207" rpy="0 0 0"/>
</joint>

<!-- ============================================================ -->
<!-- Link4 — triangular connector                                  -->
<!-- link4_mimic — mimics right × +1.0                             -->
<!-- Transfers elbow rotation to the wrist chain.                  -->
<!-- Pivots at the same point as 'right' on Link2.                 -->
<!-- ============================================================ -->
<link name="Link4">
  <inertial>
    <origin xyz="-0.00235 0.013618 0.015458" rpy="0 0 0"/>
    <mass value="0.003"/>
    <inertia ixx="0.000000316" ixy="0.000000001" ixz="0.000000177"
             iyy="0.000001679" iyz="-0.000000007" izz="0.000001378"/>
  </inertial>
  <visual>
    <geometry>
      <mesh filename="package://swiftpro_resources/urdf/Link4.STL"/>
    </geometry>
    <origin xyz="-0.0132 0 -0.24767" rpy="0 0 0"/>
    <material name="dark_grey"/>
  </visual>
</link>

<joint name="link4_mimic" type="revolute">
  <axis xyz="0 1 0"/>
  <limit effort="1000.0" lower="-3" upper="3" velocity="2.0"/>
  <parent link="Link2"/>
  <child link="Link4"/>
  <origin xyz="0 0 0.14207" rpy="0 0 0"/>
  <mimic joint="right" multiplier="1.0" offset="0.0"/>
</joint>

<!-- ============================================================ -->
<!-- Link5 — upper arm rear rod                                    -->
<!-- link5_mimic — mimics left × -1.0                              -->
<!-- Closes the upper arm parallelogram loop.                      -->
<!-- Pivots on Link1 below 'left'.                                 -->
<!-- ============================================================ -->
<link name="Link5">
  <inertial>
    <origin xyz="0.000287 0.0157 0.072444" rpy="0 0 0"/>
    <mass value="0.003"/>
    <inertia ixx="0.000004841" ixy="0.000000000" ixz="0.000000023"
             iyy="0.000004863" iyz="0.000000000" izz="0.000000023"/>
  </inertial>
  <visual>
    <geometry>
      <mesh filename="package://swiftpro_resources/urdf/Link5.STL"/>
    </geometry>
    <origin xyz="0.0215 0 -0.1223" rpy="0 0 0"/>
    <material name="dark_grey"/>
  </visual>
</link>

<joint name="link5_mimic" type="revolute">
  <axis xyz="0 1 0"/>
  <limit effort="1000.0" lower="-3" upper="3" velocity="2.0"/>
  <parent link="Link1"/>
  <child link="Link5"/>
  <origin xyz="-0.0215 0 0.05001" rpy="0 0 0"/>
  <mimic joint="left" multiplier="-1.0" offset="0.0"/>
</joint>

<!-- ============================================================ -->
<!-- Link6 — wrist rear upper rod                                  -->
<!-- link6_mimic — mimics left × +1.0                              -->
<!-- Follows shoulder rotation to position the wrist chain.        -->
<!-- ============================================================ -->
<link name="Link6">
  <inertial>
    <origin xyz="-0.014 -0.01391 -0.001062" rpy="0 0 0"/>
    <mass value="0.003"/>
    <inertia ixx="0.000000074" ixy="-0.000000060" ixz="0.000000055"
             iyy="0.000000951" iyz="-0.000000004" izz="0.000000923"/>
  </inertial>
  <visual>
    <geometry>
      <mesh filename="package://swiftpro_resources/urdf/Link6.STL"/>
    </geometry>
    <origin xyz="-0.0132 0 -0.1056" rpy="0 0 0"/>
    <material name="dark_grey"/>
  </visual>
</link>

<joint name="link6_mimic" type="revolute">
  <axis xyz="0 1 0"/>
  <limit effort="1000.0" lower="-3" upper="3" velocity="2.0"/>
  <parent link="Link1"/>
  <child link="Link6"/>
  <origin xyz="0.0132 0 0.0333" rpy="0 0 0"/>
  <mimic joint="left" multiplier="1.0" offset="0.0"/>
</joint>

<!-- ============================================================ -->
<!-- Link7 — wrist rear lower rod                                  -->
<!-- link7_mimic — mimics right × +1.0                             -->
<!-- Transfers elbow rotation through the wrist rear chain.        -->
<!-- ============================================================ -->
<link name="Link7">
  <inertial>
    <origin xyz="-0.001242 -0.013867 0.083246" rpy="0 0 0"/>
    <mass value="0.003"/>
    <inertia ixx="0.000007052" ixy="0.000000003" ixz="0.000000055"
             iyy="0.000007058" iyz="0.000000117" izz="0.000000039"/>
  </inertial>
  <visual>
    <geometry>
      <mesh filename="package://swiftpro_resources/urdf/Link7.STL"/>
    </geometry>
    <origin xyz="0.0323 0 -0.10258" rpy="0 0 0"/>
    <material name="dark_grey"/>
  </visual>
</link>

<joint name="link7_mimic" type="revolute">
  <axis xyz="0 1 0"/>
  <limit effort="1000.0" lower="-3" upper="3" velocity="2.0"/>
  <parent link="Link6"/>
  <child link="Link7"/>
  <origin xyz="-0.0455 0 -0.00301" rpy="0 0 0"/>
  <mimic joint="right" multiplier="1.0" offset="0.0"/>
</joint>

<!-- ============================================================ -->
<!-- Link8 — end effector mount / gripper body                     -->
<!-- link8_mimic — mimics right × -1.0                             -->
<!-- Cancels elbow rotation to keep the gripper level.             -->
<!-- Shoulder movement is already cancelled by the upper arm       -->
<!-- parallelogram (link5_mimic) and never reaches here.           -->
<!-- Verified against physical hardware.                           -->
<!-- ============================================================ -->
<link name="Link8">
  <inertial>
    <origin xyz="0.027288 0.001085 -0.007344" rpy="0 0 0"/>
    <mass value="0.012"/>
    <inertia ixx="0.000002184" ixy="0.000000020" ixz="-0.000000207"
             iyy="0.000002992" iyz="0.000000371" izz="0.000001832"/>
  </inertial>
  <visual>
    <geometry>
      <mesh filename="package://swiftpro_resources/urdf/Gripper.STL"/>
    </geometry>
    <origin xyz="-0.17201 0 -0.24651" rpy="0 0 0"/>
    <material name="dark_grey"/>
  </visual>
</link>

<joint name="link8_mimic" type="revolute">
  <axis xyz="0 1 0"/>
  <limit effort="1000.0" lower="-3" upper="3" velocity="2.0"/>
  <parent link="Link3"/>
  <child link="Link8"/>
  <origin xyz="0.15852 0 0" rpy="0 0 0"/>
  <mimic joint="right" multiplier="-1.0" offset="0.0"/>
</joint>

<!-- ============================================================ -->
<!-- Link9 — gripper jaw / tool tip                                -->
<!-- link9_fixed — fixed                                           -->
<!-- Not servo-driven in the base UArm Swift Pro configuration.    -->
<!-- Change to revolute + mimic if a wrist rotation servo is       -->
<!-- fitted.                                                       -->
<!-- ============================================================ -->
<link name="Link9">
  <inertial>
    <origin xyz="-0.079305 0.0157 -0.000043" rpy="0 0 0"/>
    <mass value="0.003"/>
    <inertia ixx="0.000000022" ixy="0.000000000" ixz="-0.000000002"
             iyy="0.000006517" iyz="0.000000000" izz="0.000006497"/>
  </inertial>
  <visual>
    <geometry>
      <mesh filename="package://swiftpro_resources/urdf/Link9.STL"/>
    </geometry>
    <origin xyz="-0.19941 0 -0.27471" rpy="0 0 0"/>
    <material name="dark_grey"/>
  </visual>
</link>

<joint name="link9_fixed" type="fixed">
  <parent link="Link8"/>
  <child link="Link9"/>
  <origin xyz="0.02741 0 0.02703" rpy="0 0 0"/>
</joint>

</robot>
