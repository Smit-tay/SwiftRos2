#
# Inverse kinematics: Cartesian XYZ (mm) → joint angles (firmware degrees).
# Does not move the arm. Pure computation.
# Coordinates are in firmware frame: X forward, Y left, Z up from table.

float64 x     # mm  firmware frame
float64 y     # mm  firmware frame
float64 z     # mm  firmware frame
---
float64 j1    # firmware degrees
float64 j2    # firmware degrees
float64 j3    # firmware degrees
bool    success
string  message
