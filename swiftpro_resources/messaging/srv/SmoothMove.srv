
# SmoothMove.srv
# Copyright 2025 Jack Sidman Smith
# Licensed under the MIT License.
#
# Smooth motion to a Cartesian target via an automatic via point.
# The arm arcs up through a lifted midpoint then descends to the target.
# Uses analytical IK — no firmware trajectory planner, no noise.
# Coordinates are in firmware frame: X forward, Y left, Z up from table.

float64 x        # mm  target position, firmware frame
float64 y        # mm
float64 z        # mm
float64 speed    # mm/s  tip speed per segment, 0 = default (150 mm/s)
float64 lift     # mm  extra Z lift at via point above max(start_z, end_z)
                 #     0 = default (50mm)
bool    wait     # if true, block until motion complete
---
bool    success
string  message
